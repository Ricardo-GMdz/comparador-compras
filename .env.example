# Clave de API de Anthropic. Requerida para el agente de búsqueda.
# Copiá este archivo a .env y completá el valor real (el .env está en .gitignore).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Credenciales de MercadoLibre (OPCIONALES). Si configurás ambas, se habilita
# la fuente de MercadoLibre además del web_search. Registrá una app en
# https://developers.mercadolibre.com para obtener client id y secret.
# MERCADO_LIBRE_CLIENT_ID=tu-client-id
# MERCADO_LIBRE_CLIENT_SECRET=tu-client-secret

# Localidad prioritaria para el sourcing de proveedores (OPCIONAL).
# Si se define, el agente prioriza proveedores de esa zona.
# SOURCING_LOCALIDAD=San Nicolás de los Garza, Nuevo León (zona metropolitana de Monterrey)
