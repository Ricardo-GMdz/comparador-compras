{
  "name": "comparador-compras",
  "version": "0.1.0",
  "description": "CLI agente que busca productos en internet, compara precios entre proveedores y recomienda la mejor opción",
  "type": "module",
  "license": "MIT",
  "bin": {
    "comparar": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "node dist/server/index.js",
    "dev:serve": "tsc && node dist/server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@hono/node-server": "^2.0.8",
    "commander": "^14.0.1",
    "hono": "^4.12.27",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.18.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
